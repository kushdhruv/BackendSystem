PORT=5000
NODE_ENV=development

# MongoDB Connection (for tasks)
MONGODB_URI=mongodb://127.0.0.1:27017/taskmanager?directConnection=true

# PostgreSQL Connection (for users)
POSTGRES_URI=postgres://postgres:postgres@localhost:5432/taskmanager

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
